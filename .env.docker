# ===========================================================================
# Entorno Docker - Copiar a .env antes de levantar los contenedores
# Todas las variables son requeridas para producción
# ===========================================================================

APP_NAME="NotesProyects"
APP_ENV=production
APP_KEY=                        # Se genera automáticamente si está vacío
APP_DEBUG=false
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Base de datos MySQL (usada por Docker)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=notesproyects
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ---------------------------------------------------------------------------
# Cache, Sesiones y Colas
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Laravel Reverb - WebSocket Server
# ---------------------------------------------------------------------------
REVERB_APP_ID=notesproyects-app
REVERB_APP_KEY=change-this-key-in-production
REVERB_APP_SECRET=change-this-secret-in-production
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Variables para el cliente (Vite/JavaScript)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Google OAuth (Socialite) - Opcional
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ---------------------------------------------------------------------------
# AWS S3 - Opcional
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Vite
# ---------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
